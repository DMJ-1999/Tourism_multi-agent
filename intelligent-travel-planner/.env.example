# 通义千问API配置
# 从阿里云DashScope控制台获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_api_key_here

# 模型配置 (可选: qwen-plus, qwen-max, qwen-turbo)
QWEN_MODEL=qwen-plus
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=2000

# 高德地图API配置
# 从高德开放平台获取: https://console.amap.com/
AMAP_API_KEY=your_amap_key_here
AMAP_SECURITY_KEY=

# 美团开放平台API配置
# 从美团开放平台获取: https://open.meituan.com/
MEITUAN_API_KEY=your_meituan_api_key_here

# 系统配置
DEBUG=False
MAX_RETRIES=3
